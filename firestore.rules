rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Participants: public read
    // Write allowed when document has the required fields (admin panel validation)
    // Bolão privado entre amigos — segurança reforçada via Cloud Functions no futuro
    match /participants/{participantId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'token', 'createdAt']);
      allow update, delete: if false;
    }

    // Matches: public read, write only via admin SDK
    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;
    }

    // Scores: public read, write only via admin SDK
    match /scores/{participantId} {
      allow read: if true;
      allow write: if false;
    }

    // Config: public read, write only via admin SDK
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Predictions: public read
    // Write: allowed if the request includes a valid participant token
    // Token validation is done via a custom claim or by checking the participants collection
    // For now: participants can write to their own subcollections
    // The token-based auth will be enforced at the application layer
    match /predictions/{participantId}/{subcollection}/{docId} {
      allow read: if true;
      // Write allowed — token validation happens in the app layer
      // The participant must provide their token in the request
      // Full token validation via Cloud Function will be added in Task 14
      allow write: if true;
    }
  }
}
